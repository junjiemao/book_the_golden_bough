QUARTZ_PAGE_TITLE=The Golden Bough
QUARTZ_BASE_URL=tgb.books.hatmatrix.me

# ----------------------------------------
# Cloudflare Pages deployment (GitHub Actions)
# Note: In GitHub Actions, these should be set in repository Secrets/Variables.
# ----------------------------------------
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=golden-bough
